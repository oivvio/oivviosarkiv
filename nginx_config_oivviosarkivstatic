server {
    listen 80;
	server_name oivviosarkiv.polite.se www.oivviosarkiv.polite.se;
	root /home/oivvio/sites/oivviosarkiv/output;

    index index.html;
    autoindex off;

	location / {
		try_files $uri $uri/ =404;
    }   

    location /white-like-me {
        rewrite ^/.* http://$server_name/pages/white-like-me.html permanent;
    }

    location /om-arkivet {
        rewrite ^/.* http://$server_name/pages/om-arkivet.html permanent;
    }

    listen 443 ssl; # managed by Certbot
ssl_certificate /etc/letsencrypt/live/oivviosarkiv.polite.se/fullchain.pem; # managed by Certbot
ssl_certificate_key /etc/letsencrypt/live/oivviosarkiv.polite.se/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot


    # Redirect non-https traffic to https
    if ($scheme != "https") {
         return 301 https://$host$request_uri;
    } # managed by Certbot

}
